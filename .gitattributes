# Tüm metin dosyaları LF ile saklanır, Windows'ta checkout'ta CRLF'e çevrilir
* text=auto

# Python ve metin dosyaları
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# İkili dosyalar — asla dönüştürme
*.pkl   binary
*.pth   binary
*.pt    binary
*.parquet binary
*.mp4   binary
*.png   binary
*.jpg   binary
